[Unit]
Description=SkySeaLens Ship Ingestion
After=network.target skysealens-api.service

[Service]
Type=simple
WorkingDirectory=/srv/skysealens/current
Environment=NODE_ENV=production
Environment=NODE_OPTIONS=--max-old-space-size=512
EnvironmentFile=/srv/skysealens/shared/.env
ExecStart=/usr/bin/node services/ingest-ships/src/worker.js
Restart=always
RestartSec=5

[Install]
WantedBy=multi-user.target
